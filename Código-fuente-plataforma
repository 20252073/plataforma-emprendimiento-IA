<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Impulsa — Plataforma de Emprendimiento con IA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --verde: #1A2F23;
    --verde-claro: #2C4A38;
    --crema: #F7F3EC;
    --crema-card: #FFFFFF;
    --terracota: #C75D3A;
    --terracota-oscuro: #A6492C;
    --oro: #D9A24B;
    --texto: #2D2A26;
    --texto-suave: #6B655C;
    --borde: #E4DDD0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--crema);
    color: var(--texto);
    font-family: 'Inter', sans-serif;
    line-height: 1.5;
    min-height: 100vh;
  }

  .marca-textura {
    position: fixed;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(26,47,35,0.04) 1px, transparent 0);
    background-size: 24px 24px;
    pointer-events: none;
    z-index: 0;
  }

  .contenedor {
    position: relative;
    z-index: 1;
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ===== HEADER ===== */
  header {
    background: var(--verde);
    color: var(--crema);
    padding: 18px 0;
    border-bottom: 4px solid var(--terracota);
  }

  .header-fila {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .marca {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .marca-icono {
    width: 36px;
    height: 36px;
    background: var(--terracota);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Fraunces', serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--crema);
    flex-shrink: 0;
  }

  .marca-nombre {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 22px;
    letter-spacing: 0.2px;
  }

  .marca-sub {
    font-size: 11px;
    color: var(--oro);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    font-weight: 500;
  }

  .ods-chip {
    font-size: 11px;
    background: rgba(217,162,75,0.15);
    border: 1px solid var(--oro);
    color: var(--oro);
    padding: 6px 12px;
    border-radius: 100px;
    font-weight: 600;
    letter-spacing: 0.3px;
    white-space: nowrap;
  }

  /* ===== HERO ===== */
  .hero {
    padding: 56px 0 40px;
  }

  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--terracota-oscuro);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 500;
    margin-bottom: 14px;
  }

  .hero h1 {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: clamp(32px, 5vw, 50px);
    line-height: 1.08;
    letter-spacing: -0.5px;
    max-width: 760px;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--terracota);
  }

  .hero p {
    margin-top: 18px;
    font-size: 17px;
    color: var(--texto-suave);
    max-width: 600px;
  }

  /* ===== INPUT DE IDEA ===== */
  .panel-idea {
    background: var(--crema-card);
    border: 1.5px solid var(--borde);
    border-radius: 16px;
    padding: 28px;
    margin: 32px 0 48px;
    box-shadow: 0 2px 0 rgba(26,47,35,0.04);
  }

  .panel-idea label {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--verde);
    font-weight: 600;
    margin-bottom: 10px;
  }

  .panel-idea textarea {
    width: 100%;
    border: 1.5px solid var(--borde);
    border-radius: 10px;
    padding: 14px 16px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: var(--texto);
    resize: vertical;
    min-height: 76px;
    background: var(--crema);
    transition: border-color 0.15s ease;
  }

  .panel-idea textarea:focus {
    outline: none;
    border-color: var(--terracota);
  }

  .fila-acciones {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 16px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .ejemplos {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .chip-ejemplo {
    font-size: 12.5px;
    background: var(--crema);
    border: 1px solid var(--borde);
    color: var(--texto-suave);
    padding: 6px 12px;
    border-radius: 100px;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .chip-ejemplo:hover {
    border-color: var(--terracota);
    color: var(--terracota-oscuro);
  }

  .btn-generar {
    background: var(--terracota);
    color: white;
    border: none;
    padding: 13px 26px;
    border-radius: 10px;
    font-size: 14.5px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .btn-generar:hover { background: var(--terracota-oscuro); }
  .btn-generar:disabled { background: #C9C2B4; cursor: not-allowed; }

  .spinner {
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255,255,255,0.4);
    border-top-color: white;
    border-radius: 50%;
    animation: girar 0.7s linear infinite;
    display: none;
  }

  .cargando .spinner { display: inline-block; }
  @keyframes girar { to { transform: rotate(360deg); } }

  /* ===== TABS DE MÓDULOS ===== */
  .modulos-nav {
    display: flex;
    gap: 6px;
    border-bottom: 2px solid var(--borde);
    margin-bottom: 32px;
    overflow-x: auto;
  }

  .modulo-tab {
    background: none;
    border: none;
    padding: 12px 18px;
    font-family: 'Inter', sans-serif;
    font-size: 14.5px;
    font-weight: 600;
    color: var(--texto-suave);
    cursor: pointer;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    transition: all 0.15s ease;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .modulo-tab .num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--oro);
  }

  .modulo-tab:hover { color: var(--texto); }

  .modulo-tab.activo {
    color: var(--verde);
    border-bottom-color: var(--terracota);
  }

  .modulo-panel { display: none; }
  .modulo-panel.activo { display: block; animation: aparecer 0.3s ease; }

  @keyframes aparecer {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===== ESTADO VACÍO ===== */
  .estado-vacio {
    text-align: center;
    padding: 70px 24px;
    color: var(--texto-suave);
  }

  .estado-vacio-icono {
    font-size: 30px;
    margin-bottom: 12px;
    opacity: 0.5;
  }

  .estado-vacio p { font-size: 14.5px; max-width: 380px; margin: 0 auto; }

  /* ===== FODA GRID ===== */
  .foda-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 720px) { .foda-grid { grid-template-columns: 1fr; } }

  .foda-card {
    border-radius: 14px;
    padding: 22px;
    border: 1.5px solid var(--borde);
  }

  .foda-card.fortalezas { background: #EEF3EC; border-color: #C3D6BC; }
  .foda-card.oportunidades { background: #FBF1E2; border-color: var(--oro); }
  .foda-card.debilidades { background: #FBEEEA; border-color: #E3B6A6; }
  .foda-card.amenazas { background: #F4EAEA; border-color: #D9B0AE; }

  .foda-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 17px;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .foda-card ul { list-style: none; }
  .foda-card li {
    font-size: 13.5px;
    margin-bottom: 10px;
    padding-left: 16px;
    position: relative;
    line-height: 1.45;
  }
  .foda-card li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--texto-suave);
  }
  .foda-card li strong { display: block; color: var(--texto); margin-bottom: 2px; }
  .foda-card li span { color: var(--texto-suave); }

  /* ===== PLAN DE NEGOCIO ===== */
  .plan-secciones { display: flex; flex-direction: column; gap: 4px; }

  .plan-seccion {
    background: var(--crema-card);
    border: 1.5px solid var(--borde);
    border-radius: 12px;
    padding: 20px 22px;
  }

  .plan-seccion + .plan-seccion { margin-top: 12px; }

  .plan-seccion-titulo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .plan-num {
    width: 22px; height: 22px;
    background: var(--verde);
    color: var(--crema);
    border-radius: 50%;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .plan-seccion h4 {
    font-family: 'Fraunces', serif;
    font-size: 16px;
    font-weight: 600;
  }

  .plan-seccion p { font-size: 13.5px; color: var(--texto-suave); padding-left: 32px; }

  /* ===== ANÁLISIS COMPETITIVO ===== */
  .competidor-card {
    background: var(--crema-card);
    border: 1.5px solid var(--borde);
    border-radius: 12px;
    padding: 18px 20px;
    margin-bottom: 12px;
  }

  .competidor-card h4 {
    font-family: 'Fraunces', serif;
    font-size: 15.5px;
    margin-bottom: 6px;
  }

  .competidor-card p { font-size: 13px; color: var(--texto-suave); }

  .puntuacion-diferenciacion {
    margin-top: 24px;
    background: var(--verde);
    color: var(--crema);
    border-radius: 14px;
    padding: 24px 26px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .puntuacion-num {
    font-family: 'Fraunces', serif;
    font-size: 44px;
    font-weight: 600;
    color: var(--oro);
    line-height: 1;
  }

  .puntuacion-texto p { font-size: 13.5px; opacity: 0.9; margin-top: 4px; }
  .puntuacion-texto span { font-family: 'JetBrains Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; opacity: 0.7; }

  /* ===== FINANCIERO ===== */
  .fin-form {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    background: var(--crema-card);
    border: 1.5px solid var(--borde);
    border-radius: 14px;
    padding: 22px;
    margin-bottom: 20px;
  }

  @media (max-width: 720px) { .fin-form { grid-template-columns: 1fr 1fr; } }

  .fin-campo label {
    display: block;
    font-size: 11.5px;
    color: var(--texto-suave);
    margin-bottom: 6px;
    font-weight: 600;
  }

  .fin-campo input {
    width: 100%;
    border: 1.5px solid var(--borde);
    border-radius: 8px;
    padding: 9px 10px;
    font-size: 14px;
    font-family: 'JetBrains Mono', monospace;
    background: var(--crema);
  }
  .fin-campo input:focus { outline: none; border-color: var(--terracota); }

  .fin-resultados {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 20px;
  }

  @media (max-width: 720px) { .fin-resultados { grid-template-columns: 1fr; } }

  .fin-stat {
    background: var(--crema-card);
    border: 1.5px solid var(--borde);
    border-radius: 12px;
    padding: 18px 20px;
    text-align: center;
  }

  .fin-stat .valor {
    font-family: 'Fraunces', serif;
    font-size: 28px;
    color: var(--terracota);
    font-weight: 600;
  }

  .fin-stat .etiqueta {
    font-size: 11.5px;
    color: var(--texto-suave);
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-top: 4px;
  }

  .fin-recomendacion {
    background: #FBF1E2;
    border: 1.5px solid var(--oro);
    border-radius: 12px;
    padding: 18px 20px;
    font-size: 13.5px;
    color: var(--texto);
    line-height: 1.6;
  }

  .fin-recomendacion strong { color: var(--terracota-oscuro); }

  /* ===== FOOTER ===== */
  footer {
    margin-top: 60px;
    padding: 24px 0 40px;
    border-top: 1px solid var(--borde);
    text-align: center;
    font-size: 12px;
    color: var(--texto-suave);
  }

  .error-msg {
    background: #FBEEEA;
    border: 1.5px solid #E3B6A6;
    color: var(--terracota-oscuro);
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 13.5px;
    margin-top: 16px;
  }
</style>
</head>
<body>

<div class="marca-textura"></div>

<header>
  <div class="contenedor header-fila">
    <div class="marca">
      <div class="marca-icono">I</div>
      <div>
        <div class="marca-nombre">Impulsa</div>
        <div class="marca-sub">Plataforma de Emprendimiento con IA</div>
      </div>
    </div>
    <div class="ods-chip">ODS 8 · Trabajo Decente y Crecimiento Económico</div>
  </div>
</header>

<div class="contenedor">

  <div class="hero">
    <div class="hero-eyebrow">Prototipo funcional — demo</div>
    <h1>De una idea suelta a un <em>plan validado</em>, en minutos.</h1>
    <p>Describe tu negocio y un agente de IA construye, en tiempo real, tu análisis FODA, plan de negocio, mapa de competencia y proyección financiera.</p>
  </div>

  <div class="panel-idea">
    <label>Tu idea de negocio</label>
    <textarea id="idea-input" placeholder="Ej: Delivery de comida saludable preparada por madres emprendedoras en Lima Norte...">Delivery de comida saludable preparada por madres emprendedoras en Lima Norte, con menús personalizados por objetivo nutricional.</textarea>
    <div class="fila-acciones">
      <div class="ejemplos">
        <button class="chip-ejemplo" data-ejemplo="Tienda online de artesanía textil andina con envíos a todo el Perú, hecha por artesanas de Ayacucho.">Artesanía andina</button>
        <button class="chip-ejemplo" data-ejemplo="App de tutorías escolares en vivo para colegios de zonas rurales, con profesores universitarios voluntarios.">Tutorías rurales</button>
        <button class="chip-ejemplo" data-ejemplo="Servicio de reciclaje de residuos electrónicos para pequeñas empresas en Lima, con certificado de disposición.">Reciclaje e-waste</button>
      </div>
      <button class="btn-generar" id="btn-generar">
        <span class="spinner"></span>
        <span id="btn-texto">Generar análisis con IA</span>
      </button>
    </div>
    <div id="error-zona"></div>
  </div>

  <nav class="modulos-nav">
    <button class="modulo-tab activo" data-modulo="foda"><span class="num">01</span> FODA</button>
    <button class="modulo-tab" data-modulo="plan"><span class="num">02</span> Plan de negocio</button>
    <button class="modulo-tab" data-modulo="competencia"><span class="num">03</span> Análisis competitivo</button>
    <button class="modulo-tab" data-modulo="financiero"><span class="num">04</span> Proyección financiera</button>
  </nav>

  <!-- MÓDULO 1: FODA -->
  <div class="modulo-panel activo" id="panel-foda">
    <div id="foda-vacio" class="estado-vacio">
      <div class="estado-vacio-icono">◆</div>
      <p>Escribe tu idea de negocio arriba y presiona "Generar análisis con IA" para ver tu FODA aquí.</p>
    </div>
    <div id="foda-resultado" class="foda-grid" style="display:none;"></div>
  </div>

  <!-- MÓDULO 2: PLAN DE NEGOCIO -->
  <div class="modulo-panel" id="panel-plan">
    <div id="plan-vacio" class="estado-vacio">
      <div class="estado-vacio-icono">◆</div>
      <p>El plan de negocio se generará automáticamente junto al FODA.</p>
    </div>
    <div id="plan-resultado" class="plan-secciones" style="display:none;"></div>
  </div>

  <!-- MÓDULO 3: ANÁLISIS COMPETITIVO -->
  <div class="modulo-panel" id="panel-competencia">
    <div id="competencia-vacio" class="estado-vacio">
      <div class="estado-vacio-icono">◆</div>
      <p>El mapeo de competidores y la puntuación de diferenciación aparecerán aquí.</p>
    </div>
    <div id="competencia-resultado" style="display:none;"></div>
  </div>

  <!-- MÓDULO 4: FINANCIERO -->
  <div class="modulo-panel" id="panel-financiero">
    <div class="fin-form">
      <div class="fin-campo">
        <label>Precio de venta (S/)</label>
        <input type="number" id="fin-precio" value="18" step="0.1">
      </div>
      <div class="fin-campo">
        <label>Costo variable unit. (S/)</label>
        <input type="number" id="fin-costo-var" value="7" step="0.1">
      </div>
      <div class="fin-campo">
        <label>Costos fijos mensuales (S/)</label>
        <input type="number" id="fin-costos-fijos" value="3500" step="10">
      </div>
      <div class="fin-campo">
        <label>Ventas estimadas/mes (unid.)</label>
        <input type="number" id="fin-ventas" value="450" step="1">
      </div>
    </div>
    <div class="fin-resultados">
      <div class="fin-stat">
        <div class="valor" id="fin-pe">—</div>
        <div class="etiqueta">Punto de equilibrio (unid./mes)</div>
      </div>
      <div class="fin-stat">
        <div class="valor" id="fin-margen">—</div>
        <div class="etiqueta">Margen de contribución</div>
      </div>
      <div class="fin-stat" id="fin-resultado-card">
        <div class="valor" id="fin-resultado-mes">—</div>
        <div class="etiqueta">Resultado mensual estimado (S/)</div>
      </div>
    </div>
    <div class="fin-recomendacion" id="fin-recomendacion"></div>
  </div>

</div>

<footer>
  Prototipo de demostración — Plataforma de Emprendimiento con IA · Universidad de Lima · Trabajo grupal, Junio 2026
</footer>

<script>
  // ===== Navegación entre módulos =====
  const tabs = document.querySelectorAll('.modulo-tab');
  const paneles = document.querySelectorAll('.modulo-panel');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('activo'));
      paneles.forEach(p => p.classList.remove('activo'));
      tab.classList.add('activo');
      document.getElementById('panel-' + tab.dataset.modulo).classList.add('activo');
    });
  });

  // ===== Ejemplos de idea =====
  document.querySelectorAll('.chip-ejemplo').forEach(chip => {
    chip.addEventListener('click', () => {
      document.getElementById('idea-input').value = chip.dataset.ejemplo;
    });
  });

  // ===== Generación con IA (FODA + Plan + Competencia) =====
  const btnGenerar = document.getElementById('btn-generar');
  const btnTexto = document.getElementById('btn-texto');
  const errorZona = document.getElementById('error-zona');

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function iconoFoda(tipo) {
    return { fortalezas: '＋', oportunidades: '↗', debilidades: '－', amenazas: '⚠' }[tipo] || '•';
  }

  
async function generarAnalisis() {
    const idea = document.getElementById('idea-input').value.trim();

    if (!idea) {
      errorZona.innerHTML = '<div class="error-msg">Por favor describe tu idea de negocio primero.</div>';
      return;
    }

    errorZona.innerHTML = '';
    btnGenerar.disabled = true;
    btnGenerar.classList.add('cargando');
    btnTexto.textContent = 'Analizando con IA...';

    try {
      await new Promise(r => setTimeout(r, 1200));

      const resultado = {
        foda: {
          fortalezas: [
            { titulo: "Propuesta diferenciada", detalle: "La idea presenta elementos de valor que pueden destacar frente a alternativas tradicionales." },
            { titulo: "Potencial de crecimiento", detalle: "Existe espacio para escalar operaciones de forma progresiva." },
            { titulo: "Enfoque en necesidades reales", detalle: "Responde a problemas identificables del mercado peruano." }
          ],
          oportunidades: [
            { titulo: "Digitalización creciente", detalle: "Más consumidores utilizan canales digitales para comprar y contratar servicios." },
            { titulo: "Alianzas estratégicas", detalle: "Puede apoyarse en instituciones, proveedores y comunidades locales." },
            { titulo: "Mercado en expansión", detalle: "Existen segmentos poco atendidos con potencial de desarrollo." }
          ],
          debilidades: [
            { titulo: "Marca nueva", detalle: "Será necesario invertir en confianza y posicionamiento." },
            { titulo: "Recursos limitados", detalle: "Los emprendimientos suelen iniciar con restricciones financieras." },
            { titulo: "Dependencia operativa", detalle: "La ejecución inicial puede depender de pocas personas." }
          ],
          amenazas: [
            { titulo: "Competencia establecida", detalle: "Empresas con experiencia pueden reaccionar rápidamente." },
            { titulo: "Cambios económicos", detalle: "La demanda puede verse afectada por ciclos económicos." },
            { titulo: "Incremento de costos", detalle: "Los insumos y servicios pueden aumentar de precio." }
          ]
        },
        plan: {
          resumen_ejecutivo: "El proyecto busca transformar la idea propuesta en una solución rentable y escalable para el mercado peruano.",
          descripcion_producto: "La propuesta ofrece valor mediante diferenciación, experiencia del cliente y eficiencia operativa.",
          analisis_mercado: "Existe una demanda potencial respaldada por tendencias de consumo y digitalización.",
          estrategia_comercializacion: "Se recomienda combinar redes sociales, alianzas estratégicas y marketing de recomendación.",
          estructura_organizacional: "Un equipo pequeño con funciones definidas permitirá un crecimiento sostenible.",
          proyeccion_12_meses: "Con validación temprana y control de costos, es posible alcanzar crecimiento gradual durante el primer año."
        },
        competencia: {
          competidores: [
            { nombre: "Competidor líder del sector", descripcion: "Cuenta con reconocimiento de marca y experiencia." },
            { nombre: "Alternativas digitales", descripcion: "Ofrecen soluciones similares mediante plataformas online." },
            { nombre: "Sustitutos indirectos", descripcion: "Resuelven la misma necesidad mediante enfoques distintos." }
          ],
          puntuacion_diferenciacion: 8,
          justificacion_puntuacion: "La idea presenta elementos diferenciadores con potencial para construir una ventaja competitiva."
        }
      };

      renderFoda(resultado.foda);
      renderPlan(resultado.plan);
      renderCompetencia(resultado.competencia);

    } catch (err) {
      errorZona.innerHTML = '<div class="error-msg">Error al generar el análisis.</div>';
    } finally {
      btnGenerar.disabled = false;
      btnGenerar.classList.remove('cargando');
      btnTexto.textContent = 'Generar análisis con IA';
    }
  }

function renderFoda(foda) {
    const tipos = [
      { clave: 'fortalezas', titulo: 'Fortalezas', clase: 'fortalezas' },
      { clave: 'oportunidades', titulo: 'Oportunidades', clase: 'oportunidades' },
      { clave: 'debilidades', titulo: 'Debilidades', clase: 'debilidades' },
      { clave: 'amenazas', titulo: 'Amenazas', clase: 'amenazas' }
    ];
    let html = '';
    tipos.forEach(t => {
      html += `<div class="foda-card ${t.clase}"><h3>${iconoFoda(t.clave)} ${t.titulo}</h3><ul>`;
      (foda[t.clave] || []).forEach(item => {
        html += `<li><strong>${escapeHtml(item.titulo)}</strong><span>${escapeHtml(item.detalle)}</span></li>`;
      });
      html += `</ul></div>`;
    });
    document.getElementById('foda-resultado').innerHTML = html;
    document.getElementById('foda-resultado').style.display = 'grid';
    document.getElementById('foda-vacio').style.display = 'none';
  }

  function renderPlan(plan) {
    const secciones = [
      ['Resumen ejecutivo', plan.resumen_ejecutivo],
      ['Descripción del producto o servicio', plan.descripcion_producto],
      ['Análisis de mercado', plan.analisis_mercado],
      ['Estrategia de comercialización', plan.estrategia_comercializacion],
      ['Estructura organizacional básica', plan.estructura_organizacional],
      ['Proyección de ingresos (12 meses)', plan.proyeccion_12_meses]
    ];
    let html = '';
    secciones.forEach((s, i) => {
      html += `<div class="plan-seccion">
        <div class="plan-seccion-titulo">
          <div class="plan-num">${i + 1}</div>
          <h4>${s[0]}</h4>
        </div>
        <p>${escapeHtml(s[1] || '')}</p>
      </div>`;
    });
    document.getElementById('plan-resultado').innerHTML = html;
    document.getElementById('plan-resultado').style.display = 'flex';
    document.getElementById('plan-vacio').style.display = 'none';
  }

  function renderCompetencia(comp) {
    let html = '';
    (comp.competidores || []).forEach(c => {
      html += `<div class="competidor-card"><h4>${escapeHtml(c.nombre)}</h4><p>${escapeHtml(c.descripcion)}</p></div>`;
    });
    html += `<div class="puntuacion-diferenciacion">
      <div class="puntuacion-num">${comp.puntuacion_diferenciacion}/10</div>
      <div class="puntuacion-texto">
        <span>Puntuación de diferenciación</span>
        <p>${escapeHtml(comp.justificacion_puntuacion || '')}</p>
      </div>
    </div>`;
    document.getElementById('competencia-resultado').innerHTML = html;
    document.getElementById('competencia-resultado').style.display = 'block';
    document.getElementById('competencia-vacio').style.display = 'none';
  }

  btnGenerar.addEventListener('click', generarAnalisis);

  // ===== Módulo financiero (cálculo local, sin IA — fórmulas exactas) =====
  function calcularFinanciero() {
    const pv = parseFloat(document.getElementById('fin-precio').value) || 0;
    const cvu = parseFloat(document.getElementById('fin-costo-var').value) || 0;
    const cf = parseFloat(document.getElementById('fin-costos-fijos').value) || 0;
    const ventas = parseFloat(document.getElementById('fin-ventas').value) || 0;

    const margenContribUnit = pv - cvu;
    const margenPct = pv > 0 ? (margenContribUnit / pv) * 100 : 0;
    const pe = margenContribUnit > 0 ? Math.ceil(cf / margenContribUnit) : null;
    const resultadoMes = (margenContribUnit * ventas) - cf;

    document.getElementById('fin-pe').textContent = pe !== null ? pe.toLocaleString('es-PE') : '—';
    document.getElementById('fin-margen').textContent = margenPct.toFixed(1) + '%';
    document.getElementById('fin-resultado-mes').textContent = 'S/ ' + resultadoMes.toLocaleString('es-PE', { maximumFractionDigits: 0 });

    const card = document.getElementById('fin-resultado-card');
    const valor = card.querySelector('.valor');
    valor.style.color = resultadoMes >= 0 ? '#2C4A38' : '#A6492C';

    let recomendacion = '';
    if (margenContribUnit <= 0) {
      recomendacion = '<strong>Atención:</strong> tu costo variable unitario es igual o mayor al precio de venta. Con esta estructura, nunca alcanzarás el punto de equilibrio. Revisa precios o costos antes de continuar.';
    } else if (ventas < pe) {
      const faltante = pe - ventas;
      recomendacion = `<strong>Por debajo del punto de equilibrio:</strong> con ${ventas.toLocaleString('es-PE')} unidades/mes estás vendiendo ${faltante.toLocaleString('es-PE')} unidades menos de lo necesario para cubrir tus costos fijos. Considera aumentar el volumen de ventas, subir el precio, o reducir costos fijos.`;
    } else {
      const excedente = ventas - pe;
      recomendacion = `<strong>Por encima del punto de equilibrio:</strong> estás vendiendo ${excedente.toLocaleString('es-PE')} unidades más de lo necesario para cubrir costos. Tu margen de contribución del ${margenPct.toFixed(1)}% sugiere ${margenPct < 30 ? 'que hay espacio para optimizar costos variables' : 'una estructura de costos saludable para reinvertir en crecimiento'}.`;
    }
    document.getElementById('fin-recomendacion').innerHTML = recomendacion;
  }

  ['fin-precio', 'fin-costo-var', 'fin-costos-fijos', 'fin-ventas'].forEach(id => {
    document.getElementById(id).addEventListener('input', calcularFinanciero);
  });

  calcularFinanciero();
</script>

